# logger.threshold = 4

#--------------------------------------------------------------------
# JITSI / 8x8 JaaS
#--------------------------------------------------------------------
# Preencha apenas 3 itens:
# 1) AppID
# 2) Api Key ID (nao cole PUBLIC KEY aqui)
# 3) Private Key PEM (arquivo em jwtPrivateKeyPath)
#--------------------------------------------------------------------
jitsi.enabled = true
jitsi.domain = '8x8.vc'
jitsi.appId = 'vpaas-magic-cookie-327e4a42b6d84cb5acea226acf92b2ae'
jitsi.roomPrefix = 'academy'

jitsi.jwtAudience = 'jitsi'
jitsi.jwtIssuer = 'chat'
jitsi.jwtSubject = 'vpaas-magic-cookie-327e4a42b6d84cb5acea226acf92b2ae'
jitsi.jwtRoom = '*'
jitsi.jwtApiKey = 'vpaas-magic-cookie-327e4a42b6d84cb5acea226acf92b2ae/277b50-SAMPLE_APP'
jitsi.jwtKeyId = '' # opcional (deixe vazio para usar jwtApiKey)
jitsi.jwtTtlSeconds = 7200
jitsi.jwtPrivateKeyPath = 'writable/keys/jaas-private-key.pem'
# jitsi.jwtPrivateKey = '-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----'

jitsi.defaultRecordingMode = 'file'

certificate.forceRegenerate = true

#--------------------------------------------------------------------
# CLOUDFLARE TURNSTILE (verificação de página inteira)
# Dashboard: https://dash.cloudflare.com/ → Turnstile
# Deixe enabled=false em local; em produção preencha as chaves e active.
#--------------------------------------------------------------------
cloudflare.turnstile.enabled = true
cloudflare.turnstile.siteKey = 0x4AAAAAAD76ql94EyKanrGk
cloudflare.turnstile.secretKey = 0x4AAAAAAD76qnH8R8pjLN1j8qWEtXIgCxw
cloudflare.turnstile.appearance = managed
cloudflare.turnstile.ttlSeconds = 86400

