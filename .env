#--------------------------------------------------------------------
# Example Environment Configuration file
#
# This file can be used as a starting point for your own
# custom .env files, and contains most of the possible settings
# available in a default install.
#
# By default, all of the settings are commented out. If you want
# to override the setting, you must un-comment it by removing the '#'
# at the beginning of the line.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://academy-ci4.test/'

SITE_EXCEL = 'https://hemelaly.github.io/MT-Academy---EXCEL/'
SITE_JS = 'https://edson-09.github.io/curso-js/'
# If you have trouble with `.`, you could also use `_`.
# app_baseURL = ''
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = academy
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# If you use MySQLi as tests, first update the values of Config\Database::$tests.
# database.tests.hostname = localhost
# database.tests.database = ci4_test
# database.tests.username = root
# database.tests.password = root
# database.tests.DBDriver = MySQLi
# database.tests.DBPrefix =
# database.tests.charset = utf8mb4
# database.tests.DBCollat = utf8mb4_general_ci
# database.tests.port = 3306

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------

email.protocol = smtp
email.SMTPHost = smtp.gmail.com
email.SMTPUser = hemelaly02@gmail.com
email.SMTPPass = "mydookccbushsqhq"
email.SMTPPort = 587
email.SMTPTimeout = 60
email.SMTPCrypto = tls
email.mailType = html
email.charset = utf-8
email.wordWrap = true

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key =

#--------------------------------------------------------------------
# MPESA
#--------------------------------------------------------------------

MPESA_API_KEY=i7k5yexfk58oros7tkmxk2yvllbs6kob
MPESA_PUBLIC_

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

#--------------------------------------------------------------------
# JITSI / 8x8 JaaS
#--------------------------------------------------------------------
#
# 1) Cole o APP ID (vpaas-magic-cookie-...)
# 2) Cole a Api Key (key id da 8x8 JaaS)
# 3) Cole a chave privada PEM (inline em 1 linha com \n) OU use jwtPrivateKeyPath
#
# Exemplo de room final:
#   vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/academy-minha-aula-abc123
#
jitsi.enabled = true
jitsi.domain = '8x8.vc'
jitsi.appId = 'vpaas-magic-cookie-327e4a42b6d84cb5acea226acf92b2ae'
jitsi.roomPrefix = 'academy'

# JWT claims esperadas pelo JaaS
jitsi.jwtAudience = 'jitsi'
jitsi.jwtIssuer = 'chat'
jitsi.jwtSubject = 'vpaas-magic-cookie-327e4a42b6d84cb5acea226acf92b2ae'
jitsi.jwtRoom = '*'
jitsi.jwtApiKey = '-----BEGIN PUBLIC KEY-----
